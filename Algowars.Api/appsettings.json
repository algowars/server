{
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Auth0": {
    "Domain": "",
    "Audience": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ExecutionEngines": {
    "Judge0": {
      "Enabled": true,
      "RunWorker": true,
      "BaseUrl": "",
      "ApiKey": "",
      "Host": "",
      "ShouldWait": false,
      "IsEncoded": true,
      "DefaultTimeoutInSeconds": 10
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MessageBus": {
    "Transport": "AzureServiceBus",
    "AzureServiceBus": {
      "ConnectionString": ""
    }
  },
  "Quartz": {
    "SubmissionCleanupJob": {
      "CronExpression": "0 0 * * * ?"
    },
    "SubmissionJobProcessorJob": {
      "CronExpression": "0 */2 * * * ?"
    }
  },
  "FeatureToggles": {
    "Toggles": [
      {
        "FeatureName": "SubmissionCreation",
        "Name": "Submission Creation",
        "Description": "Enable or disable the ability for users to create new submissions",
        "IsEnabled": true,
        "Strategy": "AlwaysOn",
        "RolloutPercentage": null
      },
      {
        "FeatureName": "AdvancedTestingFeatures",
        "Name": "Advanced Testing Features",
        "Description": "Enable advanced testing capabilities for problems",
        "IsEnabled": false,
        "Strategy": "AlwaysOff",
        "RolloutPercentage": null
      },
      {
        "FeatureName": "ProblemSuggestions",
        "Name": "Problem Suggestions",
        "Description": "Show personalized problem suggestions to users",
        "IsEnabled": true,
        "Strategy": "PercentageRollout",
        "RolloutPercentage": 50
      }
    ]
  }
}
